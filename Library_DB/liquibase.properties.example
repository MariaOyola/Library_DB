# Requires a local Liquibase installation with the PostgreSQL JDBC driver available.
changeLogFile=changelog-master.yaml
url=jdbc:postgresql://localhost:5436/airline_ops
username=geography_user
password=geography_password
driver=org.postgresql.Driver

